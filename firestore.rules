rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users collection
    match /users/{userId} {
      // Users can read/write their own profile; admins can read all
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      // Students subcollection (nested under parent)
      match /students/{studentId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId);
        allow update: if isOwner(userId) || isAdmin();
        allow delete: if isOwner(userId) || isAdmin();
      }
    }

    // Available booking slots — public read (for calendar), admin write
    match /availableSlots/{slotId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Bookings — parent can read/create own; admin can read/write all
    match /bookings/{bookingId} {
      allow read: if isAuthenticated() &&
        (resource.data.parentId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() &&
        request.resource.data.parentId == request.auth.uid;
      allow update: if isAdmin() ||
        (isAuthenticated() && resource.data.parentId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Resources — authenticated parents can read; admin can write
    match /resources/{resourceId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Progress reports — parent can read own child's; admin can write
    match /progressReports/{reportId} {
      allow read: if isAuthenticated() &&
        (resource.data.parentId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    // Email log — admin only
    match /emailLog/{emailId} {
      allow read, write: if isAdmin();
    }

    // Admin tasks (C2) - instructor checklist state (e.g. weekly materials prep).
    // Pure instructor surface; no parent visibility.
    match /adminTasks/{taskId} {
      allow read, write: if isAdmin();
    }

    // Probe results (C4) - weekly Orton-Gillingham probe data per student
    // (phonics accuracy %, ORF wpm, error tallies). Parents may read only
    // their own student records; admin writes all.
    match /probeResults/{id} {
      allow read: if isAdmin() ||
        (isAuthenticated() && resource.data.parentId == request.auth.uid);
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Assessment results (C5) - pre/post battery scores per student.
    // Same parent-read / admin-write contract as probeResults.
    match /assessmentResults/{id} {
      allow read: if isAdmin() ||
        (isAuthenticated() && resource.data.parentId == request.auth.uid);
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Guide leads — server-only (Cloud Functions use Admin SDK, bypassing rules)
    // Deny all client-side access; no public reads or writes
    match /guideLeads/{leadId} {
      allow read, write: if false;
    }

    // Attendance — instructor (admin) writes; parents read only their own student's
    // records. Note: Firestore rules cannot redact specific fields, so the parent UI
    // must filter `notes` (instructor-private) out at the app layer when surfacing
    // records to parents. The `parentVisibleNote` field is the safe-to-show channel.
    match /attendance/{attendanceId} {
      allow read: if isAdmin() ||
        (isAuthenticated() && resource.data.parentId == request.auth.uid);
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Notifications — parent-facing notification ledger written by Cloud Functions
    // (e.g. attendance-flag triggers). Parents read their own only; admins read
    // all. Parents may UPDATE their own notification doc but ONLY to mark it
    // read (toggle `read` + set `readAt`); they cannot mutate any other field
    // and cannot create or delete entries. Cloud Functions use the Admin SDK
    // and bypass these rules for writes.
    match /notifications/{notificationId} {
      allow read: if isAdmin() ||
        (isAuthenticated() && resource.data.parentId == request.auth.uid);
      allow update: if isAdmin() ||
        (
          isAuthenticated() &&
          resource.data.parentId == request.auth.uid &&
          request.resource.data.parentId == resource.data.parentId &&
          request.resource.data.studentId == resource.data.studentId &&
          request.resource.data.kind == resource.data.kind &&
          request.resource.data.flag == resource.data.flag &&
          request.resource.data.attendanceDocId == resource.data.attendanceDocId &&
          request.resource.data.createdAt == resource.data.createdAt
        );
      allow create, delete: if false; // server-only via Admin SDK
    }
  }
}
