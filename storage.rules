rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // IEP uploads — parents can upload/read their own files; admin can read all
    match /ieps/{userId}/{allPaths=**} {
      allow read: if request.auth != null &&
        (request.auth.uid == userId || request.auth.token.admin == true);
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024  // 10MB max
        && request.resource.contentType.matches('application/pdf');
    }

    // Resources — authenticated can read; admin can write
    match /resources/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.admin == true
        && request.resource.size < 25 * 1024 * 1024;  // 25MB max
    }

    // Progress reports — parent can read own; admin can write
    match /reports/{userId}/{allPaths=**} {
      allow read: if request.auth != null &&
        (request.auth.uid == userId || request.auth.token.admin == true);
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // E3 — Signed enrollment agreements (server-written; client read-only)
    match /signedAgreements/{enrollmentId} {
      allow read: if request.auth != null;
      // Authorization (own vs admin) is enforced server-side via
      // getSignedAgreementPdf; client direct reads work only if firestore
      // metadata permits, but we keep this gate auth-required to fail safe.
      allow write: if false;
    }

    // E3 — Per-uid raw signature images (audit-only; admin + owner read)
    match /signatures/{userId}/{allPaths=**} {
      allow read: if request.auth != null &&
        (request.auth.uid == userId || request.auth.token.admin == true);
      allow write: if false;
    }
  }
}
