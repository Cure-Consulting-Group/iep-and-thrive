app_identifier "com.cureconsulting.IEPAndThrive"

# apple_id and team_id are NOT pinned here — we authenticate via the
# App Store Connect API key (key_id + issuer_id + key_content) loaded
# from environment variables in the Fastfile. That key carries all the
# team context Fastlane needs.
#
# If you need to use the legacy Apple ID password flow (e.g. for an
# action that requires it explicitly), set these via env vars instead:
#   FASTLANE_USER, FASTLANE_TEAM_ID
